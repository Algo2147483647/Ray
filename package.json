{
  "name": "ray-workspace",
  "private": true,
  "scripts": {
    "ray": "go -C engine/go run ./cmd/ray",
    "ray:test": "go -C engine/go test ./...",
    "ray:build": "go -C engine/go build -o ../../bin/ray ./cmd/ray",
    "ui": "npm --prefix apps/scene-editor run dev",
    "ui:install": "npm --prefix apps/scene-editor install",
    "ui:build": "npm --prefix apps/scene-editor run build",
    "ui:preview": "npm --prefix apps/scene-editor run preview"
  }
}
