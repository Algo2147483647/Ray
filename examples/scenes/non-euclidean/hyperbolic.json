{
  "render": {
    "dimension": 3,
    "samples": 200,
    "thread_num": 0,
    "width": 400,
    "height": 400,
    "camera_index": 0,
    "output_image": "../outputs/hyperbolic_gallery.png",
    "output_film": "../outputs/hyperbolic_gallery.bin",
    "exposure": 1.0,
    "tone_mapping": "aces",
    "gamma": 2.2,
    "spectrum_mode": "rgb",
    "color_space": "linear_srgb"
  },
  "geometry": {
    "type": "klein",
    "max_arc": 0
  },

  "_comment_camera": "Camera placed near the Klein boundary (|p| ~ 0.92) and looking across the ball. From here, hyperbolic distance to the origin is ~1.6 and to a point at x=0.95 is ~3.4 — the chord is short Euclideanly but very long hyperbolically.",
  "cameras": [
    {
      "id": "main",
      "type": "hyperbolic",
      "position": [-0.88, 0.0, 0.10],
      "look_at":  [ 0.92, 0.0, 0.08],
      "up":       [ 0.0,  0.0, 1.0],
      "width": 400, "height": 400,
      "field_of_view": 100.0,
      "aspect_ratio": 1.0
    }
  ],

  "materials": [
    { "id": "floor_white",   "surface": { "type": "lambert", "albedo": [0.92, 0.92, 0.92] } },
    { "id": "floor_dark",    "surface": { "type": "lambert", "albedo": [0.06, 0.06, 0.08] } },
    { "id": "wall_warm",     "surface": { "type": "lambert", "albedo": [0.72, 0.42, 0.32] } },
    { "id": "wall_cool",     "surface": { "type": "lambert", "albedo": [0.30, 0.42, 0.65] } },
    { "id": "wall_back",     "surface": { "type": "lambert", "albedo": [0.85, 0.85, 0.88] } },
    { "id": "ruler_a",       "surface": { "type": "lambert", "albedo": [0.95, 0.20, 0.18] } },
    { "id": "ruler_b",       "surface": { "type": "lambert", "albedo": [0.96, 0.55, 0.12] } },
    { "id": "ruler_c",       "surface": { "type": "lambert", "albedo": [0.95, 0.92, 0.20] } },
    { "id": "ruler_d",       "surface": { "type": "lambert", "albedo": [0.20, 0.85, 0.30] } },
    { "id": "ruler_e",       "surface": { "type": "lambert", "albedo": [0.18, 0.62, 0.95] } },
    { "id": "ruler_f",       "surface": { "type": "lambert", "albedo": [0.55, 0.30, 0.95] } },
    { "id": "ruler_g",       "surface": { "type": "lambert", "albedo": [0.95, 0.95, 0.95] } },
    { "id": "ball_mirror",   "surface": { "type": "specular_reflection", "reflectance": [0.96, 0.96, 0.96] } },

    { "_comment": "Strong key light placed near the camera so even very-far hyperbolic points still receive enough flux to read against the volumetric absorption.",
      "id": "key_light",
      "emission": { "type": "constant", "radiance": { "type": "blackbody", "temperature": 5800, "scale": 14.0 } } },
    { "_comment": "Brighter fill at the far end so the long hyperbolic path lights the deep ruler against the cool fog without over-clipping the near end.",
      "id": "fill_light",
      "emission": { "type": "constant", "radiance": { "type": "blackbody", "temperature": 7200, "scale": 28.0 } } }
  ],

  "objects": [
    { "_comment_floor": "Floor is built from a regular Euclidean checker grid in Klein coordinates. Because Klein metric distorts the spatial scale near the boundary, the squares closer to the camera look enormous while the ones near +x crowd into a thin strip — a much stronger 'hyperbolic perspective' than uniform Euclidean perspective.",

      "id": "tile_-3_-3", "material_id": "floor_white", "shape": "cuboid", "center": [-0.75, -0.75, -0.005], "size": [0.30, 0.30, 0.01] },
    { "id": "tile_-3_-2", "material_id": "floor_dark",  "shape": "cuboid", "center": [-0.75, -0.45, -0.005], "size": [0.30, 0.30, 0.01] },
    { "id": "tile_-3_-1", "material_id": "floor_white", "shape": "cuboid", "center": [-0.75, -0.15, -0.005], "size": [0.30, 0.30, 0.01] },
    { "id": "tile_-3_+0", "material_id": "floor_dark",  "shape": "cuboid", "center": [-0.75,  0.15, -0.005], "size": [0.30, 0.30, 0.01] },
