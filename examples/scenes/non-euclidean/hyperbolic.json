    { "_comment_walls": "Side walls pushed close to the boundary on each side. Most of their surface is hyperbolically far from the camera, so they read as deeply attenuated coloured horizons rather than flat planes.",
      "id": "wall_-y", "material_id": "wall_warm", "shape": "cuboid", "center": [ 0.0, -0.93, 0.18], "size": [1.80, 0.02, 0.36] },
    { "id": "wall_+y", "material_id": "wall_cool", "shape": "cuboid", "center": [ 0.0,  0.93, 0.18], "size": [1.80, 0.02, 0.36] },
    { "id": "wall_+x", "material_id": "wall_back", "shape": "cuboid", "center": [ 0.96, 0.0,  0.18], "size": [0.02, 1.80, 0.36] },

    { "_comment_ruler": "Hyperbolic ruler: seven spheres at uniformly spaced Klein x = 0..0.96. Hyperbolic distances from x=-0.92 to these points are ~1.59, 1.91, 2.16, 2.41, 2.69, 3.09, 3.46 — i.e. the row is uniformly spaced in Klein coords yet looks crowded near the far end and shows visibly stronger hyperbolic-fog absorption with each step.",
      "id": "ruler_0", "material_id": "ruler_a", "shape": "sphere", "position": [-0.32,  0.18, 0.06], "r": 0.05 },
    { "id": "ruler_1", "material_id": "ruler_b", "shape": "sphere", "position": [-0.05, -0.18, 0.06], "r": 0.05 },
    { "id": "ruler_2", "material_id": "ruler_c", "shape": "sphere", "position": [ 0.22,  0.18, 0.06], "r": 0.05 },
    { "id": "ruler_3", "material_id": "ruler_d", "shape": "sphere", "position": [ 0.48, -0.18, 0.06], "r": 0.05 },
    { "id": "ruler_4", "material_id": "ruler_e", "shape": "sphere", "position": [ 0.70,  0.18, 0.06], "r": 0.05 },
    { "id": "ruler_5", "material_id": "ruler_f", "shape": "sphere", "position": [ 0.84, -0.16, 0.06], "r": 0.045 },
    { "id": "ruler_6", "material_id": "ruler_g", "shape": "sphere", "position": [ 0.92,  0.13, 0.06], "r": 0.035 },

    { "_comment_mirror": "Chrome balls flanking the corridor catch wide reflections of the curved checker grid + warm/cool walls; reflected paths also accrue hyperbolic absorption, so the reflection itself is visibly tinted by the metric.",
      "id": "mirror_ball",  "material_id": "ball_mirror", "shape": "sphere", "position": [-0.30, -0.55, 0.08], "r": 0.08 },
    { "id": "mirror_ball2", "material_id": "ball_mirror", "shape": "sphere", "position": [-0.30,  0.55, 0.08], "r": 0.08 },

    { "_comment_lights": "Key light is right above the camera so its rays mostly travel short hyperbolic distances and stay bright. Fill at +x is hyperbolically far, so its contribution is heavily absorbed and tints the back of the scene.",
      "id": "light_key",  "material_id": "key_light",
      "shape": "cuboid", "center": [-0.45, 0.0, 0.40], "size": [0.40, 0.80, 0.02] },
    { "id": "light_fill", "material_id": "fill_light",
      "shape": "cuboid", "center": [ 0.55, 0.0, 0.40], "size": [0.40, 0.80, 0.02] }
