    { "id": "tile_+1_+2", "material_id": "floor_dark",  "shape": "cuboid", "center": [ 0.45,  0.75, -0.005], "size": [0.30, 0.30, 0.01] },

    { "id": "tile_+2_-3", "material_id": "floor_dark",  "shape": "cuboid", "center": [ 0.75, -0.75, -0.005], "size": [0.30, 0.30, 0.01] },
