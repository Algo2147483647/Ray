    { "id": "tile_+1_-2", "material_id": "floor_dark",  "shape": "cuboid", "center": [ 0.45, -0.45, -0.005], "size": [0.30, 0.30, 0.01] },
    { "id": "tile_+1_-1", "material_id": "floor_white", "shape": "cuboid", "center": [ 0.45, -0.15, -0.005], "size": [0.30, 0.30, 0.01] },
    { "id": "tile_+1_+0", "material_id": "floor_dark",  "shape": "cuboid", "center": [ 0.45,  0.15, -0.005], "size": [0.30, 0.30, 0.01] },
